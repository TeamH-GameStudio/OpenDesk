/* ============================================================
   Pokedex Test — UI Toolkit Styles
   All transitions are declared on BASE selectors so that
   changes in either direction (apply / remove modifier)
   animate symmetrically.
   ============================================================ */

.root {
    flex-grow: 1;
    flex-direction: column;
    background-color: rgb(20, 24, 32);
    color: rgb(232, 236, 244);
    -unity-font-style: normal;
}

/* ----------- Header ----------- */
.header {
    flex-direction: column;
    padding: 12px 16px;
    background-color: rgb(28, 32, 44);
    border-bottom-width: 1px;
    border-bottom-color: rgb(50, 56, 72);
}

.title {
    font-size: 22px;
    -unity-font-style: bold;
    color: rgb(255, 215, 0);
    margin-bottom: 8px;
}

.toolbar {
    flex-direction: row;
    align-items: center;
}

.search-field {
    flex-grow: 1;
    margin-right: 12px;
}

.search-field > .unity-text-field__input {
    background-color: rgb(40, 46, 60);
    border-width: 1px;
    border-color: rgb(70, 78, 96);
    border-radius: 6px;
    padding: 6px 10px;
    color: rgb(232, 236, 244);

    transition-property: border-color, background-color;
    transition-duration: 0.15s, 0.15s;
    transition-timing-function: ease-out;
}

.search-field > .unity-text-field__input:focus {
    border-color: rgb(120, 170, 255);
    background-color: rgb(48, 54, 70);
}

.favorites-toggle {
    flex-shrink: 0;
}

.favorites-toggle Label {
    color: rgb(220, 224, 232);
    margin-left: 4px;
}

/* ----------- Content ----------- */
.content {
    flex-grow: 1;
    flex-direction: row;
}

.list-pane {
    width: 50%;
    min-width: 280px;
    flex-direction: column;
    background-color: rgb(24, 28, 40);
    border-right-width: 1px;
    border-right-color: rgb(50, 56, 72);
}

.pokemon-list {
    flex-grow: 1;
}

.pokemon-list .unity-collection-view__item {
    background-color: rgba(0, 0, 0, 0);
    padding: 0;

    transition-property: background-color;
    transition-duration: 0.18s;
    transition-timing-function: ease-out;
}

.pokemon-list .unity-collection-view__item:hover {
    background-color: rgba(120, 170, 255, 0.10);
}

.pokemon-list .unity-collection-view__item--selected {
    background-color: rgba(120, 170, 255, 0.22);
}

/* ----------- List Item ----------- */
.pokemon-item {
    flex-direction: row;
    align-items: center;
    height: 56px;
    padding: 8px 14px;
    border-bottom-width: 1px;
    border-bottom-color: rgba(70, 78, 96, 0.4);

    /* Base-state transitions */
    transition-property: translate, background-color;
    transition-duration: 0.18s, 0.18s;
    transition-timing-function: ease-out;
    translate: 0 0;
}

.pokemon-item:hover {
    translate: 4px 0;
    background-color: rgba(120, 170, 255, 0.06);
}

.item-number {
    width: 56px;
    color: rgb(160, 170, 190);
    -unity-font-style: bold;
    font-size: 13px;
}

.item-name {
    flex-grow: 0;
    flex-shrink: 0;
    width: 110px;
    color: rgb(232, 236, 244);
    -unity-font-style: bold;
    font-size: 14px;
}

.item-spacer {
    flex-grow: 1;
}

.item-types {
    flex-direction: row;
    align-items: center;
    margin-right: 10px;
}

.item-types > .type-pill {
    margin-left: 4px;
}

/* ----------- Type Pills ----------- */
.type-pill {
    padding: 2px 10px;
    margin-right: 6px;
    border-radius: 999px;
    font-size: 11px;
    -unity-font-style: bold;
    color: rgb(255, 255, 255);
    background-color: rgb(120, 130, 150);

    transition-property: background-color;
    transition-duration: 0.2s;
    transition-timing-function: ease-out;
}

.type-pill--small {
    font-size: 10px;
    padding: 1px 8px;
}

.type-normal   { background-color: rgb(168, 168, 120); }
.type-fire     { background-color: rgb(240, 128, 48); }
.type-water    { background-color: rgb(104, 144, 240); }
.type-grass    { background-color: rgb(120, 200, 80); }
.type-electric { background-color: rgb(248, 208, 48); color: rgb(40, 30, 0); }
.type-ice      { background-color: rgb(152, 216, 216); color: rgb(20, 30, 40); }
.type-fighting { background-color: rgb(192, 48, 40); }
.type-poison   { background-color: rgb(160, 64, 160); }
.type-ground   { background-color: rgb(224, 192, 104); color: rgb(40, 30, 0); }
.type-flying   { background-color: rgb(168, 144, 240); }
.type-psychic  { background-color: rgb(248, 88, 136); }
.type-bug      { background-color: rgb(168, 184, 32); }
.type-rock     { background-color: rgb(184, 160, 56); }
.type-ghost    { background-color: rgb(112, 88, 152); }
.type-dragon   { background-color: rgb(112, 56, 248); }
.type-dark     { background-color: rgb(112, 88, 72); }
.type-steel    { background-color: rgb(184, 184, 208); color: rgb(20, 30, 40); }
.type-fairy    { background-color: rgb(238, 153, 172); color: rgb(40, 20, 30); }

/* ----------- Favorite Icon ----------- */
.favorite-icon {
    width: 26px;
    -unity-text-align: middle-center;
    font-size: 18px;
    color: rgba(255, 255, 255, 0.18);
    scale: 1 1;

    /* All transitions on base */
    transition-property: color, scale;
    transition-duration: 0.18s, 0.22s;
    transition-timing-function: ease-out, ease-out;
}

.favorite-icon--active {
    color: rgb(255, 215, 0);
}

.favorite-icon--pulsing {
    scale: 1.5 1.5;
}

/* ----------- Detail Panel (Slide Transition) ----------- */
.detail-panel {
    flex-grow: 1;
    flex-direction: column;
    padding: 24px;
    background-color: rgb(24, 28, 40);
    overflow: hidden;

    /* Base-state transitions for slide + fade */
    translate: 100% 0;
    opacity: 0;
    transition-property: translate, opacity;
    transition-duration: 0.32s, 0.32s;
    transition-timing-function: ease-out, ease-out;
}

.detail-panel--visible {
    translate: 0 0;
    opacity: 1;
}

.detail-empty {
    flex-grow: 1;
    align-items: center;
    justify-content: center;
}

.detail-empty-text {
    font-size: 16px;
    color: rgb(140, 150, 170);
}

.detail-content {
    flex-grow: 1;
    flex-direction: column;
    display: none;
}

.detail-header {
    flex-direction: row;
    align-items: flex-end;
    margin-bottom: 10px;
}

.detail-number {
    font-size: 16px;
    color: rgb(160, 170, 190);
    margin-right: 12px;
    -unity-font-style: bold;
}

.detail-name {
    font-size: 28px;
    -unity-font-style: bold;
    color: rgb(255, 215, 0);
}

.detail-types {
    flex-direction: row;
    margin-bottom: 18px;
}

/* ----------- Stats ----------- */
.stats {
    flex-direction: column;
    margin-bottom: 18px;
    padding: 12px 16px;
    background-color: rgb(34, 40, 54);
    border-radius: 8px;
}

.stat-row {
    flex-direction: row;
    justify-content: space-between;
    padding: 4px 0;
}

.stat-label {
    color: rgb(160, 170, 190);
    font-size: 13px;
}

.stat-value {
    color: rgb(232, 236, 244);
    -unity-font-style: bold;
    font-size: 13px;
}

.detail-description {
    color: rgb(200, 208, 220);
    font-size: 13px;
    white-space: normal;
    margin-bottom: 18px;
    padding: 12px 14px;
    background-color: rgb(34, 40, 54);
    border-radius: 8px;
}

/* ----------- Favorite Button ----------- */
.favorite-button {
    align-self: flex-start;
    padding: 8px 16px;
    background-color: rgb(60, 70, 90);
    border-width: 1px;
    border-color: rgb(80, 92, 116);
    border-radius: 8px;
    color: rgb(220, 224, 232);
    -unity-font-style: bold;
    font-size: 13px;
    scale: 1 1;

    /* Base-state transitions */
    transition-property: background-color, border-color, color, scale;
    transition-duration: 0.18s, 0.18s, 0.18s, 0.22s;
    transition-timing-function: ease-out, ease-out, ease-out, ease-out;
}

.favorite-button:hover {
    background-color: rgb(72, 84, 110);
    border-color: rgb(120, 170, 255);
}

.favorite-button--active {
    background-color: rgb(255, 215, 0);
    border-color: rgb(220, 180, 0);
    color: rgb(40, 30, 0);
}

.favorite-button.favorite-icon--pulsing {
    scale: 1.08 1.08;
}
